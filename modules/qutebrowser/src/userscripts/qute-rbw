#!/usr/bin/env bash
#-------------------------------------------------------------------------------
# Qutebrowser userscript: qute-rbw
#
# Populate login fields using rbw (the unofficial Bitwarden CLI daemon).
# Uses spawn-launcher.sh (via $LAUNCHER) as the selection menu.
# Remembers which vault entry was chosen for each domain and reuses it on
# subsequent runs, skipping the menu.
#
# Usage (from qutebrowser config.py):
#   spawn --userscript qute-rbw              # fill username + password
#   spawn --userscript qute-rbw --submit     # fill username + password, submit
#   spawn --userscript qute-rbw --username   # fill username only
#   spawn --userscript qute-rbw --password   # fill password only
#   spawn --userscript qute-rbw --totp       # fill TOTP code
#   spawn --userscript qute-rbw --select     # re-pick the entry for this domain
#
# Dependencies: rbw, jq, spawn-launcher.sh (in $PATH), libnotify (notify-send)
#-------------------------------------------------------------------------------

set -euo pipefail

source "$XDG_OPT_HOME/shell-utils/debug.sh"

# Helpers
#-------------------------------------------------------------------------------

die() {
    echo "$*" >&2
    exit 1
}

qute() {
    printf '%s\n' "$*" >> "$QUTE_FIFO"
}

notify() {
    notify-send "$(basename "$0")" "$*"
}

# Fill a form field by CSS selector using jseval.
# Sets the value and fires input+change events so JS frameworks react.
# The value is passed URL-encoded to avoid any quoting issues with special
# characters (single quotes, backslashes, etc.) in passwords.
fill_field() {
    local selector="$1"
    local value="$2"
    # URL-encode the value so it survives embedding in a JS string literal.
    # jq @uri percent-encodes everything outside RFC 3986 unreserved characters
    # (including % and ') so a single decodeURIComponent restores it exactly.
    local encoded
    encoded=$(printf '%s' "$value" | jq -Rr @uri)
    # Use a heredoc for readability, then strip all newlines before writing to
    # the FIFO — qutebrowser treats each newline as a separate command.
    local js
    js=$(tr -d '\n' <<ENDOFJS
    (function(){
        var el = document.querySelector('${selector}');
        if (!el) return;
        var val = decodeURIComponent('${encoded}');
        var n = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value');
        if (n && n.set) { n.set.call(el, val); } else { el.value = val; }
        el.dispatchEvent(new Event('input',  {bubbles:true}));
        el.dispatchEvent(new Event('change', {bubbles:true}));
    })()
ENDOFJS
)
    qute "jseval -q ${js}"
}

# Click the login/submit/continue button for the form we just filled.
# Scopes the search to the form containing the password (or username) field,
# falling back to the whole document. The click is delayed so JS frameworks
# can process the input events fired by fill_field first.
submit_form() {
    local js
    js=$(tr -d '\n' <<ENDOFJS
    setTimeout(function(){
        var field = document.querySelector('${PASSWORD_SELECTOR}')
                 || document.querySelector('${USERNAME_SELECTOR}');
        if (!field) return;
        var scope = field.form || document;
        var btn = scope.querySelector('button[type=submit], input[type=submit]');
        if (!btn) {
            var re = /log ?in|sign ?in|submit|continue|next/i;
            btn = Array.prototype.filter.call(
                scope.querySelectorAll('button, input[type=button], [role=button]'),
                function(b){ return re.test((b.innerText || b.value || '').trim()); }
            )[0];
        }
        if (btn) { btn.click(); }
        else if (field.form && field.form.requestSubmit) { field.form.requestSubmit(); }
    }, 200)
ENDOFJS
)
    qute "jseval -q ${js}"
}

# Type a string into the currently focused element using fake-key.
# Used as a fallback when there is no reliable field selector (e.g. TOTP).
type_text() {
    local text="$1"
    local i char
    for (( i = 0; i < ${#text}; i++ )); do
        char="${text:$i:1}"
        if [[ "$char" == " " ]]; then
            qute 'fake-key " "'
        else
            qute "fake-key '\\${char}'"
        fi
    done
}

# Domain → entry associations
#-------------------------------------------------------------------------------
# Persisted as TSV lines of "domain<TAB>entry-uuid". A remembered association
# resolves the entry directly by UUID, skipping the filter and selection menu.

assoc_file="${QUTE_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/qutebrowser}/qute-rbw-associations.tsv"

assoc_lookup() {
    [[ -f "$assoc_file" ]] || return 0
    awk -F'\t' -v d="$1" '$1 == d { print $2; exit }' "$assoc_file"
}

assoc_save() {
    local domain="$1" id="$2" tmp
    mkdir -p "$(dirname "$assoc_file")"
    tmp=$(mktemp "$assoc_file.XXXXXX")
    [[ -f "$assoc_file" ]] && awk -F'\t' -v d="$domain" '$1 != d' "$assoc_file" > "$tmp"
    printf '%s\t%s\n' "$domain" "$id" >> "$tmp"
    mv "$tmp" "$assoc_file"
}

assoc_forget() {
    local domain="$1" tmp
    [[ -f "$assoc_file" ]] || return 0
    tmp=$(mktemp "$assoc_file.XXXXXX")
    awk -F'\t' -v d="$domain" '$1 != d' "$assoc_file" > "$tmp"
    mv "$tmp" "$assoc_file"
}

# Parse arguments
#-------------------------------------------------------------------------------

mode="both"  # both | username | password | totp
submit=0
force_select=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --username|-u)  mode="username" ;;
        --password|-p)  mode="password" ;;
        --totp|-t)      mode="totp"     ;;
        --submit|-s)    submit=1        ;;
        --select)       force_select=1  ;;
        --help|-h)
            echo "Usage: qute-rbw [--username|--password|--totp] [--submit] [--select]"
            exit 0
            ;;
        *)
            die "Unknown argument: $1"
            ;;
    esac
    shift
done

# Validate environment
#-------------------------------------------------------------------------------

[[ -n "${QUTE_URL:-}" ]]  || die "QUTE_URL is not set. Run this script from qutebrowser."
[[ -n "${QUTE_FIFO:-}" ]] || die "QUTE_FIFO is not set. Run this script from qutebrowser."

command -v rbw            > /dev/null 2>&1 || die "rbw not found in PATH."
command -v spawn-launcher.sh > /dev/null 2>&1 || die "spawn-launcher.sh not found in PATH."

# Ensure rbw agent is running and vault is unlocked
#-------------------------------------------------------------------------------

if ! rbw unlocked 2>/dev/null; then
    rbw unlock 2>/dev/null || { debug::error_notify "unlock failed or was cancelled."; exit 1; }
fi

# Extract the hostname from the current URL for pre-filtering
#-------------------------------------------------------------------------------

# Strip scheme, strip path/query, lowercase
raw_host="${QUTE_URL#*://}"
raw_host="${raw_host%%/*}"
raw_host="${raw_host%%\?*}"
raw_host="${raw_host,,}"

# Drop www. prefix for matching
domain="${raw_host#www.}"

# Resolve a remembered association first
#-------------------------------------------------------------------------------
# A stale association (entry deleted from the vault) is dropped and the normal
# selection flow takes over.

entry_json=""
selected_id=""

if [[ $force_select -eq 0 && -n "$domain" ]]; then
    cached_id=$(assoc_lookup "$domain")
    if [[ -n "$cached_id" ]]; then
        if entry_json=$(rbw get --raw "$cached_id" 2>/dev/null); then
            selected_id="$cached_id"
        else
            assoc_forget "$domain"
            entry_json=""
        fi
    fi
fi

# Build candidate list and show the selection menu
#-------------------------------------------------------------------------------
# Format from `rbw list --fields`: id<TAB>name<TAB>user<TAB>folder
# We build display lines of the form:  name · user [folder]
# and keep a parallel array mapping display index → entry UUID.

if [[ -z "$entry_json" ]]; then
    all_entries=$(rbw list --fields id,name,user,folder 2>/dev/null) || {
        debug::error_notify "failed to list entries."
        exit 1
    }

    # Pre-filter: entries whose name or user contains the domain. With
    # --select the full list is offered so a mismatched filter or stale
    # association can always be corrected.
    if [[ $force_select -eq 1 || -z "$domain" ]]; then
        filtered="$all_entries"
    else
        filtered=$(echo "$all_entries" | grep -iF "$domain" || true)
    fi

    # Fall back to the full list if nothing matched
    if [[ -z "$filtered" ]]; then
        filtered="$all_entries"
    fi

    declare -a display_lines=()
    declare -a entry_ids=()

    while IFS=$'\t' read -r id name user folder; do
        [[ -z "$id" ]] && continue

        # Build a human-readable display line
        label="$name"
        [[ -n "$user"   ]] && label+="  ·  $user"
        [[ -n "$folder" ]] && label+="  [$folder]"

        display_lines+=("$label")
        entry_ids+=("$id")
    done <<< "$filtered"

    if [[ ${#display_lines[@]} -eq 0 ]]; then
        debug::error_notify "no entries found for ${domain:-this page}."
        exit 0
    fi

    chosen=""
    menu_shown=0

    if [[ ${#display_lines[@]} -eq 1 && $force_select -eq 0 ]]; then
        # Only one candidate — skip the menu
        chosen="${display_lines[0]}"
    else
        menu_shown=1
        prompt="Bitwarden ($domain)"
        chosen=$(printf '%s\n' "${display_lines[@]}" \
            | spawn-launcher.sh --menu --prompt "$prompt") || true
    fi

    [[ -z "$chosen" ]] && exit 0  # user cancelled

    for i in "${!display_lines[@]}"; do
        if [[ "${display_lines[$i]}" == "$chosen" ]]; then
            selected_id="${entry_ids[$i]}"
            break
        fi
    done

    if [[ -z "$selected_id" ]]; then
        debug::error_notify "could not resolve selection."
        exit 1
    fi

    entry_json=$(rbw get --raw "$selected_id" 2>/dev/null) || {
        debug::error_notify "failed to retrieve the selected entry."
        exit 1
    }

    # Remember explicit picks so the menu is skipped next time
    if [[ $menu_shown -eq 1 && -n "$domain" ]]; then
        assoc_save "$domain" "$selected_id"
    fi
fi

# Extract credentials
#-------------------------------------------------------------------------------

selected_name=$(echo "$entry_json" | jq -r '.name // "entry"')
username=$(echo "$entry_json" | jq -r '.data.username // empty')
password=$(echo "$entry_json" | jq -r '.data.password // empty')
totp_secret=$(echo "$entry_json" | jq -r '.data.totp // empty')

# Fill the form
#-------------------------------------------------------------------------------
# For username/password modes we use jseval to locate and fill the correct
# input field directly — no reliance on prior focus state.
# CSS selector precedence for the username field:
#   1. input[type=email]   — most login forms
#   2. input[type=text]    — fallback for non-email username fields
# For TOTP there is no reliable heuristic, so we fall back to fake-key into
# whatever element the user has focused.

USERNAME_SELECTOR="input[type=email]:not([disabled]):not([hidden]), input[type=text]:not([disabled]):not([hidden])"
PASSWORD_SELECTOR="input[type=password]:not([disabled]):not([hidden])"

case "$mode" in
    username)
        [[ -z "$username" ]] && { debug::error_notify "no username for '${selected_name}'."; exit 1; }
        fill_field "$USERNAME_SELECTOR" "$username"
        ;;

    password)
        [[ -z "$password" ]] && { debug::error_notify "no password for '${selected_name}'."; exit 1; }
        fill_field "$PASSWORD_SELECTOR" "$password"
        ;;

    totp)
        if [[ -z "$totp_secret" ]]; then
            debug::error_notify "no TOTP for '${selected_name}'."
            exit 1
        fi
        totp_code=$(rbw code "$selected_id" 2>/dev/null) || {
            debug::error_notify "failed to generate TOTP for '${selected_name}'."
            exit 1
        }
        qute 'mode-enter insert'
        type_text "$totp_code"
        ;;

    both)
        if [[ -z "$username" && -z "$password" ]]; then
            debug::error_notify "no credentials for '${selected_name}'."
            exit 1
        fi
        [[ -n "$username" ]] && fill_field "$USERNAME_SELECTOR" "$username"
        [[ -n "$password" ]] && fill_field "$PASSWORD_SELECTOR" "$password"
        ;;
esac

if [[ $submit -eq 1 && "$mode" != "totp" ]]; then
    submit_form
    notify "filled and submitted '${selected_name}'."
else
    notify "filled '${selected_name}'."
fi
