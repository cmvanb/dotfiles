/* <% source $XDG_OPT_HOME/theme/theme.sh -%> */

/* General styling */
body {
    background-color: <% color_hash $primary_1 %> !important;
    color: <% color_hash $text_10 %> !important;
    font-family: sans-serif;
    font-size: <%= $font_size_medium %>px;
    line-height: 1.6;

    max-width: 720px;
    margin: 0 auto;
    padding: 2em;
}

p {
    margin: 0;
    padding: 0;
}

h1, h2, h3, h4, h5, h6 {
    margin: 20px 0 10px;
    padding: 0;
    font-weight: bold;
    -webkit-font-smoothing: subpixel-antialiased;
    cursor: text;
}

h1 {
    font-size: 28px;
    border-bottom: none !important;
    color: <% color_hash $text_15 %> !important;
}

h2 {
    font-size: 24px;
    border-bottom: 1px solid <% color_hash $gray_4 %> !important;
    color: <% color_hash $text_15 %> !important;
}

h3 {
    font-size: <%= $font_size_xlarge %>px;
    color: <% color_hash $text_14 %> !important;
}

h4 {
    font-size: <%= $font_size_large %>px;
    color: <% color_hash $text_14 %> !important;
}

h5 {
    font-size: <%= $font_size_medium %>px;
    color: <% color_hash $text_13 %> !important;
}

h6 {
    font-size: <%= $font_size_medium %>px;
    color: <% color_hash $text_12 %> !important;
}

/* Links */
a {
    color: <% color_hash $primary_12 %> !important;
    text-decoration: none;
}

a:focus {
    outline: thin dotted;
}

a:visited {
    color: <% color_hash $gray_8 %> !important;
}

a:active,
a:hover {
    color: <% color_hash $primary_15 %> !important;
    text-decoration: underline;

    outline: 0;
}

/* Code and pre */
code, tt {
    margin: 0 2px;
    padding: 0 5px;
    white-space: nowrap;
    background-color: <% color_hash $editor_bg %> !important;
    border: 1px solid <% color_hash $gray_1 %> !important;
    border-radius: 3px;
    font-family: monospace;
    font-size: <%= $font_size_medium %>px;
    color: <% color_hash $secondary_11 %> !important;
}

em {
    color: <% color_hash $secondary_15 %> !important;
    style: italic;
}

strong {
    color: <% color_hash $secondary_15 %> !important;
    font-weight: bold;
}

pre {
    background-color: <% color_hash $editor_bg %> !important;
    border: 1px solid <% color_hash $gray_1 %> !important;
    border-radius: 3px;
    font-size: <%= $font_size_msmall %>px;
    line-height: 19px;
    overflow: auto;
    padding: 6px 10px;
}

pre > code, pre > tt {
    background-color: transparent !important;
    border: 0 !important;
    margin: 0;
    padding: 0;
    white-space: pre;
    color: inherit !important;
    font-size: inherit;
}

/* Tables */
table {
    border: 1px solid <% color_hash $gray_4 %> !important;
    border-collapse: collapse;
    background-color: <% color_hash $gray_0 %> !important;
}

th {
    background-color: <% color_hash $gray_2 %> !important;
    color: <% color_hash $text_15 %> !important;
    border: 1px solid <% color_hash $gray_4 %> !important;
    padding: 8px 12px;
    font-weight: bold;
}

td {
    border: 1px solid <% color_hash $gray_4 %> !important;
    padding: 8px 12px;
    color: <% color_hash $text_10 %> !important;
}

tr:nth-child(even) {
    background-color: <% color_hash $gray_1 %> !important;
}

tr:hover {
    background-color: <% color_hash $gray_2 %> !important;
}

/* Forms and inputs */
input, textarea, select, button {
    background-color: <% color_hash $gray_1 %> !important;
    color: <% color_hash $text_10 %> !important;
    border: 1px solid <% color_hash $gray_4 %> !important;
    border-radius: 3px;
    padding: 6px 10px;
}

input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: <% color_hash $primary_8 %> !important;
    box-shadow: 0 0 0 2px <% color_css_rgba $primary_8 0.2 %>;
}

button {
    background-color: <% color_hash $primary_6 %> !important;
    color: <% color_hash $text_15 %> !important;
    cursor: pointer;
}

button:hover {
    background-color: <% color_hash $primary_8 %> !important;
}

/* Lists */
ul, ol {
    color: <% color_hash $text_10 %> !important;
    padding-left: 1.5em;
}

ul > li {
    color: <% color_hash $text_10 %> !important;
}

ul > li > * {
    color: <% color_hash $text_10 %> !important;
}

li {
    margin: 0.3em 0;
}

dt {
    color: <% color_hash $text_13 %> !important;
    font-weight: bold;
}

dd {
    margin-left: 1.5em;
}

/* Horizontal rule */
hr {
    border: 0;
    border-top: 1px solid <% color_hash $gray_4 %> !important;
    margin: 1em 0;
}

/* Blockquotes */
blockquote {
    border-left: 4px solid <% color_hash $gray_5 %> !important;
    padding-left: 1em;
    color: <% color_hash $text_10 %> !important;
    margin: 1em 0;
}

/* qute://help specific */
div.admonitionblock {
    margin-top: 1em;
    margin-bottom: 1em;
    margin-left: 0;
    margin-right: 0;
    padding: 0;
}

#sidebar {
    background-color: <% color_hash $gray_1 %> !important;
    border-right: 1px solid <% color_hash $gray_4 %> !important;
}

#preamble {
    margin: 0;
}

#content {
    background-color: <% color_hash $primary_2 %> !important;
    border-radius: 0.8em;
    padding: 1.5em;
    margin-top: 1.5em;
}

.sectionbody {
    padding-left: 0.5em;
    padding-right: 0.5em;
}

/* first child doesn't need a margin */
#content .sect1:first-child * {
    margin-top: 0;
}

.deprecated {
    color: <% color_hash $red_6 %> !important;
}

/* qute://settings specific */
.setting {
    border: 1px solid <% color_hash $gray_3 %> !important;
    background-color: <% color_hash $gray_1 %> !important;
    margin: 0.5em 0;
    padding: 1em;
}

.setting:hover {
    background-color: <% color_hash $gray_2 %> !important;
}

/* qute://history specific */
.url {
    color: <% color_hash $secondary_12 %> !important;
}

.title {
    color: <% color_hash $text_13 %> !important;
}

.time {
    color: <% color_hash $text_8 %> !important;
}

/* Search highlighting */
mark, .highlight {
    background-color: <% color_hash $yellow_3 %> !important;
    color: <% color_hash $text_15 %> !important;
}
