{
  "permissions": {
    "additionalDirectories": [
      "~/.config",
      "~/.local"
    ],
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "Bash(cargo *)",
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(echo *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(hostnamectl *)",
      "Bash(inxi *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(rg *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(uniq *)",
      "Bash(uv *)",
      "Bash(which *)",
      "Bash(xargs *)"
    ],
    "deny": [
      "Read(*.env)",
      "Read(*.env.*)"
    ]
  },
  "model": "",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); type=$(printf '%s' \"$input\" | jq -r '.notification_type'); [ \"$type\" != \"idle_prompt\" ] && notify-send \"Claude Code\" \"$(printf '%s' \"$input\" | jq -r '.message')\" || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"$HOME/.config/claude/CLAUDE.md\"; for f in CLAUDE.md .claude.md; do [ -f \"$(pwd)/$f\" ] && echo \"$(pwd)/$f\"; done; for f in AGENTS.md .agents.md agents.md; do if [ -f \"$f\" ]; then echo \"$(pwd)/$f\"; cat \"$f\"; break; fi; done'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "preferredNotifChannel": "notifications_disabled",
  "inputNeededNotifEnabled": false
}
