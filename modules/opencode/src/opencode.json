{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "gpt-oss-20b-mxfp4": {
          "name": "GPT-OSS 20B mxfp4 (local)",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        }
      }
    }
  },
  "model": "llama-cpp/gpt-oss-20b-mxfp4",
  "autoupdate": false,
  "plugin": [
    "opencode-anthropic-oauth@latest"
  ],
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/Code/**": "allow",
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "edit": {
      "*": "allow",
      "~/Code/**": "ask",
    },
    "glob": {
      "*": "allow",
    },
    "grep": {
      "*": "allow",
    },
    "list": {
      "*": "allow",
    },
    "bash": {
      "*": "ask",
      "git *": "ask",
      "python *": "ask",
      "rm *": "ask",
      "ls *": "allow",
      "cp *": "allow",
      "which *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "fd *": "allow",
      "git diff *": "allow",
      "git status *": "allow",
      "head *": "allow",
      "sort *": "allow",
      "mkdir *": "allow",
      "cargo *": "allow",
      "uniq *": "allow",
      "xargs *": "allow",
    },
    "task": {
      "*": "allow",
    },
    "skill": {
      "*": "allow",
    },
    "lsp": {
      "*": "allow",
    },
    "webfetch": "allow",
    "websearch": "ask",
    "codesearch": "ask",
  }
}
