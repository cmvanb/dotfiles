{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "autoupdate": false,
  "plugin": ["opencode-claude-auth"],
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/Code/**": "allow",
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "edit": {
      "*": "allow",
      "~/Code/**": "ask",
    },
    "glob": {
      "*": "allow",
    },
    "grep": {
      "*": "allow",
    },
    "list": {
      "*": "allow",
    },
    "bash": {
      "*": "ask",
      "rm *": "ask",
      "ls *": "allow",
      "cp *": "allow",
      "which *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "fd *": "allow",
      "git *": "ask",
      "git diff *": "allow",
      "git status *": "allow",
      "head *": "allow",
      "sort *": "allow",
      "mkdir *": "allow",
      "cargo *": "allow",
    },
    "task": {
      "*": "allow",
    },
    "skill": {
      "*": "ask",
    },
    "lsp": {
      "*": "allow",
    },
    "webfetch": "allow",
    "websearch": "ask",
    "codesearch": "ask",
  }
}
